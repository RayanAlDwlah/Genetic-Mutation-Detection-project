# Python cache
__pycache__/
*.py[cod]

# Jupyter
.ipynb_checkpoints/

# Data
# Keep raw data out of git
data/raw/*
!data/raw/.gitkeep

# Processed and split datasets can be large
data/processed/*
!data/processed/.gitkeep
data/splits/*
!data/splits/.gitkeep

# Large CSV files
*.csv

# Training artifacts
checkpoints/
results/checkpoints/*
!results/checkpoints/.gitkeep

# Virtual environments
.venv/
venv/
env/

# OS / editor
.DS_Store
.vscode/
.idea/
