# Python cache
__pycache__/
*.py[cod]

# Jupyter
.ipynb_checkpoints/

# Data
# Keep raw data out of git
data/raw/*
!data/raw/.gitkeep

# Processed and split datasets can be large
data/processed/*
!data/processed/.gitkeep
!data/processed/final_balanced.parquet
!data/processed/final_strict.parquet
!data/processed/merged_clinvar_gnomad_dbnsfp.parquet
data/splits/*
!data/splits/.gitkeep
!data/splits/train.parquet
!data/splits/val.parquet
!data/splits/test.parquet
!data/splits/strict/
data/splits/strict/*
!data/splits/strict/train.parquet
!data/splits/strict/val.parquet
!data/splits/strict/test.parquet
!data/splits/phase21/
data/splits/phase21/*
!data/splits/phase21/train.parquet
!data/splits/phase21/val.parquet
!data/splits/phase21/test.parquet

# Large CSV files
*.csv

# Training artifacts
checkpoints/
results/checkpoints/
!results/checkpoints/
results/checkpoints/*
!results/checkpoints/.gitkeep
!results/checkpoints/*.ubj
results/metrics/*
!results/metrics/.gitkeep
!results/metrics/*.csv
!results/metrics/phase21/
results/metrics/phase21/*
!results/metrics/phase21/*.csv

# Assistant worktrees
.claude/

# Virtual environments
.venv/
venv/
env/

# OS / editor
.DS_Store
.vscode/
.idea/

# Intermediate artifacts
data/intermediate/*
!data/intermediate/.gitkeep
!data/intermediate/clinvar_labeled_clean.parquet
!data/intermediate/dbnsfp_selected_features.parquet
!data/intermediate/gnomad_af_clean.parquet

# Generated figures
results/figures/*
!results/figures/.gitkeep
!results/figures/*.png

# Stage 0 additions
.coverage
coverage.xml
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Exception: ESM-2 Stage 2.1 score parquets (needed for reproducibility)
!data/intermediate/esm2/scores_train.parquet
!data/intermediate/esm2/scores_val.parquet
!data/intermediate/esm2/scores_test.parquet
