# Python cache
__pycache__/
*.py[cod]

# Jupyter
.ipynb_checkpoints/

# Data
# Keep raw data out of git
data/raw/*
!data/raw/.gitkeep

# Processed and split datasets can be large
data/processed/*
!data/processed/.gitkeep
!data/processed/final_balanced.parquet
!data/processed/final_strict.parquet
!data/processed/merged_clinvar_gnomad_dbnsfp.parquet
data/splits/*
!data/splits/.gitkeep
!data/splits/train.parquet
!data/splits/val.parquet
!data/splits/test.parquet
!data/splits/strict/
data/splits/strict/*
!data/splits/strict/train.parquet
!data/splits/strict/val.parquet
!data/splits/strict/test.parquet

# Large CSV files
*.csv

# Training artifacts
checkpoints/
results/checkpoints/
results/checkpoints/*
!results/checkpoints/.gitkeep
results/metrics/*.csv

# Assistant worktrees
.claude/

# Virtual environments
.venv/
venv/
env/

# OS / editor
.DS_Store
.vscode/
.idea/

# Intermediate artifacts
data/intermediate/*
!data/intermediate/.gitkeep
!data/intermediate/clinvar_labeled_clean.parquet
!data/intermediate/dbnsfp_selected_features.parquet
!data/intermediate/gnomad_af_clean.parquet

# Generated figures
results/figures/*
!results/figures/.gitkeep
